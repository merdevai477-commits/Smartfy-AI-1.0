# backend/.env.example — Copy to .env and fill in values

# ─── Application ─────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://smartfyai.com,https://www.smartfyai.com

# ─── Database (Postgres / Supabase) ──────────────────────
# Use the Supabase connection string (URI format). URL-encode special characters in password if needed.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project>.supabase.co:5432/postgres
# Set to true ONLY for first deploy to auto-create tables
SYNC_DB=false

# ─── Authentication (Clerk) ───────────────────────────────
CLERK_SECRET_KEY=sk_live_...

# ─── AI Providers ────────────────────────────────────────
GROQ_API_KEY=
